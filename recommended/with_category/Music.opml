<?xml version='1.0' encoding='UTF-8' ?>
<opml version="1.0">
	<head>
		<title>Export from Plenary</title>
		<url>https://play.google.com/store/apps/details?id=com.spians.plenary</url>
		<ownerName>Spians Labs</ownerName>
		<ownerEmail>info@spianslabs.com</ownerEmail>
	</head>
	<body>
		<outline text="Music" title="Music">
			
			<outline text="Consequence" title="Consequence" description="Music, Film, TV and Pop Culture News for the Mainstream and Underground" xmlUrl="http://consequenceofsound.net/feed" type="rss" />
			
			<outline text="Metal Injection" title="Metal Injection" description="Heavy metal news, metal music videos, tour dates, live footage, exclusive documentaries, funny clips and more." xmlUrl="http://feeds.feedburner.com/metalinjection" type="rss" />
			<outline text="Music Business Worldwide" title="Music Business Worldwide" description="News, jobs and analysis for the global music industry" xmlUrl="https://www.musicbusinessworldwide.com/feed/" type="rss" />
			<outline text="RSS: News" title="RSS: News" description="News content RSS feed" xmlUrl="http://pitchfork.com/rss/news" type="rss" />
			<outline text="Song Exploder" title="Song Exploder" description="A podcast where musicians take apart their songs, and piece by piece, tell the story of how they were made." xmlUrl="http://songexploder.net/feed" type="rss" />
			
		</outline>
	</body>
</opml>